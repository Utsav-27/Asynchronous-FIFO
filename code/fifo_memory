module fifo_memory #(parameter Dsize = 8, depth = 8, parameter Asize = 4)(
    input wclk, rclk, wen_true, ren_true,
    input [Asize-1 :0] wadd, radd,
    input [Dsize-1:0] data_in,
    output reg [Dsize-1:0] data_out
);
    reg [Dsize-1:0] mem [0:depth-1];
        
    always @(posedge wclk) begin
        if (wen_true) begin
            mem[wadd] <= data_in;
        end
    end

    always @(posedge rclk) begin
        if(ren_true) begin
            data_out <= mem[radd];
        end
    end
endmodule
