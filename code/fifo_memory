module fifo_memory #(parameter Dsize = 8, parameter Asize = 4)(
    input wclk, rclk, wen, ren, full, empty,
    input [Dsize-1:0] data_in,
    input [Asize-1 :0] wadd, radd,
    output reg [Dsize-1:0] data_out
);
    
    parameter depth = 1<<Asize;
    reg [Dsize-1:0] mem [0:depth-1];
    
    always @(posedge wclk) begin
        if (wen && !full) begin
            mem[wadd] <= data_in;
        end
    end

    always @(posedge rclk) begin
        if(ren && !empty) begin
            data_out <= mem[radd];
        end
    end
endmodule
