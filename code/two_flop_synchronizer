module fifo_2_flop_sync #(parameter Asize = 3) (
    input [Asize : 0]data_in,
    input clk,rst,
    output wire [Asize : 0] data_out
);
    reg [Asize : 0] ff1,ff2;
    always @(posedge clk or negedge rst) begin
        if(!rst) begin
            ff1 <= 0;
            ff2 <= 0;
        end
        else begin
            ff1 <= data_in;
            ff2 <= ff1;
        end
    end
    assign data_out = ff2;
endmodule
