module fifo_2_flop_sync #(parameter Asize = 4) (
    input clk,rst,
    input [Asize : 0]data_in,
    output reg [Asize : 0] data_out
);
    reg [Asize : 0] ff;
    always @(posedge clk or negedge rst) begin
        if(!rst) begin
            ff <= 0;
            data_out <= 0;
        end
        else begin
            data_out <= ff;
            ff <= data_in;
        end
    end

endmodule
